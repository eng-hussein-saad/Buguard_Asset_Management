# Application
APP_NAME=Buguard Asset Management API
ENVIRONMENT=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# Database
POSTGRES_USER=buguard
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=buguard_asset_management
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://buguard:replace-me@db:5432/buguard_asset_management

# Security
SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_HASH_SCHEME=bcrypt

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate limiting and caching
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=memory
REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=false
CACHE_TTL_SECONDS=60

# LangChain / OpenAI bonus feature
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANALYSIS_MAX_ASSETS=100

# Logging
LOG_LEVEL=INFO
